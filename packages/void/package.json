{
  "name": "void",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "void": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./virtual.d.ts",
      "default": "./dist/db.js"
    },
    "./kv": {
      "types": "./virtual.d.ts"
    },
    "./storage": {
      "types": "./virtual.d.ts"
    },
    "./queue": {
      "types": "./virtual.d.ts"
    }
  },
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "citty": "^0.1.6",
    "fast-glob": "^3.3.3"
  },
  "peerDependencies": {
    "vite": "^6.0.0",
    "drizzle-orm": "^0.38.0",
    "drizzle-kit": "^0.30.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@cloudflare/workers-types": "^4.20250312.0",
    "@types/node": "^22.0.0"
  }
}
