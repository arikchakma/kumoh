{
  "name": "kumoh",
  "version": "0.0.3",
  "description": "Opinionated framework for building Cloudflare Workers",
  "homepage": "https://github.com/arikchakma/kumoh#readme",
  "bugs": {
    "url": "https://github.com/arikchakma/kumoh/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arikchakma/kumoh.git",
    "directory": "packages/kumoh"
  },
  "bin": {
    "kumoh": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "virtual.d.ts",
    "tsconfig.base.json",
    "kumoh.schema.json"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cron": {
      "types": "./dist/cron.d.mts",
      "default": "./dist/cron.mjs"
    },
    "./db": {
      "types": "./virtual.d.ts",
      "default": "./dist/db.mjs"
    },
    "./kv": {
      "types": "./virtual.d.ts"
    },
    "./storage": {
      "types": "./virtual.d.ts"
    },
    "./queue": {
      "types": "./virtual.d.ts",
      "default": "./dist/queue.mjs"
    },
    "./ai": {
      "types": "./virtual.d.ts"
    },
    "./email": {
      "types": "./virtual.d.ts"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    },
    "./app": {
      "types": "./virtual.d.ts",
      "import": "./dist/app.mjs"
    },
    "./tsconfig": "./tsconfig.base.json"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "prepare": "vp pack",
    "prepublishOnly": "vp run build",
    "release": "bumpp"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "better-sqlite3": "^12.8.0",
    "citty": "^0.2.2",
    "fast-glob": "^3.3.3",
    "knitwork": "^1.3.0",
    "oxc-parser": "^0.123.0",
    "wrangler": "^4.80.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260404.1",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "hono": "^4.12.10",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "vite": "^8.0.0"
  }
}
